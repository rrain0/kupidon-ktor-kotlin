
# Сначала идём в ktor nginx proxy
# Вручную надо установить в локальном nginx
PROXY_HOST=kupidon.dev.rraindev
# Вручную надо установить в локальном nginx
PROXY_PORT=40012
# Вручную надо установить в локальном nginx
PROXY_CERT_CRT=./nginx/cert-dev/kupidon.dev.rraindev.pem.crt
# Вручную надо установить в локальном nginx
PROXY_CERT_KEY=./nginx/cert-dev/kupidon.dev.rraindev.pem.key

# Потом ktor nginx proxy идёт в ktor
# Вручную надо установить в локальном nginx
# Автоподтягивается в application.conf
KTOR_PORT=40019

# Дальше ktor идёт в mongo
MONGO_HOST=kupidon.dev.rraindev
MONGO_PORT=40022
MONGO_RS=rs0
MONGO_DATABASE=kupidon
# PKCS12 certificate with pwd "0000"
MONGO_BACKEND_CLIENT_CERT=D:\PROG\Projects\kupidon\kupidon-mongo\mongo\certs-dev\mongoAppBackendClient.pkcs12
# PEM certificate
MONGO_CA_CERT=D:\PROG\Projects\kupidon\kupidon-mongo\mongo\certs-dev\mongo-ca.pem.crt

